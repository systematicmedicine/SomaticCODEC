"""
--- Snakefile_test_ms_filtered_vcf_output ---

Test Snakefile to be used with function test_ms_filtered_vcf_output

Runs matched sample pipeline from filter-flagged VCF to filtered VCF

Inputs: 
    - Merged and filter-flagged VCF
Output: 
    - Filtered VCF

Author: Joshua Johnstone

"""

# Load libraries
import os
import pandas as pd

# Load additional config data
ms_samples = pd.read_csv(config["ms_samples_path"])

# Include rules files
include: "../../rules/ms_call_germ.smk"

rule all:
    input:
        expand("tmp/{ms_sample}/{ms_sample}_ms_filtered_variants.vcf.gz", ms_sample = ms_samples["ms_sample"].tolist())
