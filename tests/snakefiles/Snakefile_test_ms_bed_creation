"""
--- Snakefile_test_ms_bed_creation ---

Test Snakefile to be used with test_ms_bed_creation.py

Runs matched sample pipeline from BAM and VCF files to creating bed files

Inputs: 
    - ms markdup BAM
Output: 
    - ms filtered VCF

Author: Joshua Johnstone

"""

# Load libraries
import os
import pandas as pd

# Load additional config data
ms_samples = pd.read_csv(config["ms_samples_path"])

# Include rules files
include: "../../rules/masked_regions.smk"

rule all:
    input:
        expand("tmp/{ms_sample}/{ms_sample}_lowdepth.bed", ms_sample = ms_samples["ms_sample"].tolist()),
        expand("tmp/{ms_sample}/{ms_sample}_GL_variants_snv.bed", ms_sample = ms_samples["ms_sample"].tolist())
