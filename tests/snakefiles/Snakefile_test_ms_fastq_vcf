"""
--- Snakefile_test_ms_fastq_vcf ---

Test Snakefile to be used with test_ms_fastq_vcf.py

Runs matched sample pipeline from demuxed FASTQs to creating a filter-flagged vcf

Inputs: 
    - 100 read pairs mapping to the middle of Chr1
    - Micro reference (1Mbp in the middle of Chr1)
Output: 
    - Merged and filter-flagged vcf

Author: Joshua Johnstone

"""

# Load libraries
import os
import pandas as pd

# Load additional config data
ms_samples = pd.read_csv(config["ms_samples_path"])

# Include rules files
include: "../../rules/ms_preprocess_fastq.smk"
include: "../../rules/ms_alignment.smk"
include: "../../rules/ms_call_germ.smk"

rule all:
    input:
        expand("tmp/{ms_sample}/{ms_sample}_ms_merge_filtered.vcf.gz", ms_sample = ms_samples["ms_sample"].tolist())
