"""
--- Snakefile_test_ms_fastq2alignment ---

Test Snakefile to be used with Snakefile_test_ms_fastq2alignment.py

Runs matched sample pipeline from demuxed FASTQs to alignment

Inputs: 
    - 100 read pairs mapping to the middle of Chr1
    - Micro reference (1Mbp in the middle of Chr1)
Output: 
    - Sorted bam with duplicates marked

Author: Joshua Johnstone

"""

# Load libraries
import os
import pandas as pd

# Load additional config data
ms_samples = pd.read_csv(config["ms_samples_path"])

# Include rules files
include: "../../rules/ms_preprocess_fastq.smk"
include: "../../rules/ms_alignment.smk"

rule all:
    input:
        expand("tmp/{ms_sample}/{ms_sample}_markdup.bam", ms_sample = ms_samples["ms_sample"].tolist()),
        expand("tmp/{ms_sample}/{ms_sample}_markdup.bai", ms_sample = ms_samples["ms_sample"].tolist())

