"""
--- Snakefile_test_ms_fastq2alignment ---

Test Snakefile to be used with Snakefile_test_ms_fastq2alignment.py

Runs matched sample pipeline from demuxed FASTQs to alignment

Inputs: 
    - 100 read pairs mapping to the middle of Chr1
    - Micro reference (1Mbp in the middle of Chr1)
Output: 
    - Sorted bam with duplicates marked

Author: Joshua Johnstone

"""

# Load libraries
import os
import pandas as pd

# Load sample names
ms_sample_names = pd.read_csv(config["ms_samples_path"])["ms_sample"].to_list()

# Include rules files
include: "../../rules/ms_preprocess_fastq.smk"
include: "../../rules/ms_alignment.smk"

rule all:
    input:
        expand("tmp/{ms_sample}/{ms_sample}_markdup.bam", ms_sample = ms_sample_names),
        expand("tmp/{ms_sample}/{ms_sample}_markdup.bai", ms_sample = ms_sample_names),
        expand("metrics/{ms_sample}/{ms_sample}_markdup_metrics.txt", ms_sample = ms_sample_names),
        expand("metrics/{ms_sample}/{ms_sample}_alignment_stats.txt", ms_sample = ms_sample_names),
        expand("metrics/{ms_sample}/{ms_sample}_insert_size_metrics.txt", ms_sample = ms_sample_names),
        expand("metrics/{ms_sample}/{ms_sample}_insert_size_histogram.pdf", ms_sample = ms_sample_names)

