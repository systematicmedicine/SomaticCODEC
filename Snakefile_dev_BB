        expand("tmp/metrics/{sample}_variantCall_summary.txt", sample=SAMPLES),
        expand("tmp/data/bed/{sample}_het_variants.bed", sample=SAMPLES),
        expand("tmp/data/pseudoref/{sample}_personalised_ref.fasta", sample=SAMPLES)
