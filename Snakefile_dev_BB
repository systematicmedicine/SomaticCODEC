        expand("tmp/{ms_sample}/{ms_sample}_ms_candidate_variants.vcf.gz", ms_sample=ms_sample),
        expand("tmp/{ms_sample}/{ms_sample}_germ_deletions.bed", ms_sample=ms_sample),
        expand("metrics/{ms_sample}/{ms_sample}_variantCall_summary.txt", ms_sample=ms_sample)
