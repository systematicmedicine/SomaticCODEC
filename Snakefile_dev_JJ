# Rule all defines all the output that the pipeline will create

rule all:
    input:
        expand("tmp/metrics/fastqc/{sample}_r1_fastqc.html", sample = sample),
        expand("tmp/metrics/fastqc/{sample}_r2_fastqc.html", sample = sample),
        expand("tmp/data/{sample}_processed_r1.fastq.gz", sample = sample),
        expand("tmp/data/{sample}_processed_r2.fastq.gz", sample = sample),
        expand("tmp/metrics/fastp/{sample}_fastp.html", sample = sample),
        expand("tmp/metrics/fastp/{sample}_fastp.json", sample = sample),
        expand("tmp/metrics/fastqc/{sample}_processed_r1_fastqc.html", sample = sample),
        expand("tmp/metrics/fastqc/{sample}_processed_r2_fastqc.html", sample = sample),
        expand("{ref}.bwt", ref = ref),
        expand("{ref}.pac", ref = ref),
        expand("{ref}.ann", ref = ref),
        expand("{ref}.amb", ref = ref),
        expand("{ref}.sa", ref = ref),
        expand("tmp/results/{sample}_aligned.bam", sample = sample),
        expand("tmp/results/{sample}_sorted.bam", sample = sample),
        expand("tmp/metrics/alignment/{sample}_samtools_stats.txt", sample = sample),
        expand("tmp/metrics/alignment/{sample}_insert_size_metrics.txt", sample = sample),
        expand("tmp/metrics/alignment/{sample}_insert_size_histogram.pdf", sample = sample),
        expand("tmp/results/{sample}_markdup.bam", sample = sample),
        expand("tmp/results/{sample}_markdup.bai", sample = sample),
        expand("tmp/metrics/markdup/{sample}_markdup_metrics.txt", sample = sample)





















